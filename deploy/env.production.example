# django-ical — production env keys, seeded into SSM /ical/prod via
# deploy/seed-parameter-store.sh. Values here are PLACEHOLDERS only; the real
# values live solely in SSM Parameter Store (fetched to tmpfs /run/ical/.env on
# the box by django-ical-env-fetch.service). Do NOT commit real secrets.
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=ical.foxugly.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://ical.foxugly.com
DJANGO_SITE_DOMAIN=ical.foxugly.com
DJANGO_STATE=PROD
DATABASE_URL=sqlite:////var/www/django_websites/django-ical/db.sqlite3
DJANGO_MAX_UPLOAD_BYTES=2097152
DJANGO_EVENT_DURATION_MINUTES=90
DJANGO_SITE_TIMEZONE=Europe/Brussels
DJANGO_HSTS_SECONDS=2592000
# Optional — set to the Sentry "ical-backend" project DSN to enable error reporting.
DJANGO_SENTRY_DSN=
