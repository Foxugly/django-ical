# django-ical — production env keys, seeded into SSM /ical/prod via
# deploy/seed-parameter-store.sh. Values here are PLACEHOLDERS only; the real
# values live solely in SSM Parameter Store (fetched to tmpfs /run/ical/.env on
# the box by django-ical-env-fetch.service). Do NOT commit real secrets.
SECRET_KEY=change-me
DEBUG=False
ALLOWED_HOSTS=ical.foxugly.com
CSRF_TRUSTED_ORIGINS=https://ical.foxugly.com
SITE_DOMAIN=ical.foxugly.com
DJANGO_ENV=PROD
# Database — fleet DB_* 6-var convention (OPERATIONS.md §3.13); prod = box-local PostgreSQL.
# (DATABASE_URL is still honoured as an override for the clean_import tooling/tests.)
DB_ENGINE=postgresql
DB_NAME=ical
DB_USER=ical
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=5432
MAX_UPLOAD_BYTES=2097152
EVENT_DURATION_MINUTES=90
SITE_TIMEZONE=Europe/Brussels
HSTS_SECONDS=2592000
# Optional — set to the Sentry "ical-backend" project DSN to enable error reporting.
SENTRY_DSN=
