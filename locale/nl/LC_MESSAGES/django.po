msgid "Tutorial"
msgstr "Handleiding"

#: .\templates\model_form_upload.html:81
msgid "Give a name and a valid csv file"
msgstr "Geef een naam en een geldig CSV-bestand"

#: .\templates\model_form_upload.html:82
msgid "Format of csv file : <code>Date;Hour;Subject;detail;Address;</code>"
msgstr "CSV-bestandsformaat: <code>Datum;Uur;Onderwerp;detail;Adres;</code>"

#: .\templates\model_form_upload.html:83
msgid ""
"For sport calendar : <code>Date;Hour;Team Home;Team Away;Address;</code>"
msgstr "Voor sportkalender: <code>Datum;Uur;Thuisploeg;Uitploeg;Adres;</code>"

#: .\templates\model_form_upload.html:84
msgid ""
"Example : <code>31/12/2021;21.30;RBP;SCC;Avenue Des Vaillants 2 1200 Woluwé-"
"St-Lambert;</code>"
msgstr "Voorbeeld: <code>31/12/2021;21.30;RBP;SCC;Avenue Des Vaillants 2 1200 Woluwé-St-Lambert;</code>"

#: .\templates\model_form_upload.html:86
msgid "Format for date : <code>dd/mm/yyyy</code> or <code>yyyy-mm-dd</code>"
msgstr "Datumformaat: <code>dd/mm/jjjj</code> of <code>jjjj-mm-dd</code>"

#: .\templates\model_form_upload.html:87
msgid "Format for hour : <code>hh:mm</code> or <code>hh.mm</code>"
msgstr "Tijdformaat: <code>uu:mm</code> of <code>uu.mm</code>"
