# Deploy-critical files MUST stay LF on the Linux box — a CR (\r) breaks bash,
# systemd ExecStart and nginx config parsing. Force LF regardless of core.autocrlf.
*.sh                          text eol=lf
*.service                     text eol=lf
*.conf                        text eol=lf
*.yml                         text eol=lf
*.yaml                        text eol=lf
deploy/sudoers.d/*            text eol=lf
deploy/env.production.example text eol=lf
